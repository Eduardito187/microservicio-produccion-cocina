APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
GRAFANA_ROOT_URL=http://localhost:3000
PROMETHEUS_PORT=9090
LOKI_PORT=3100
CADVISOR_PORT=8081
NODE_EXPORTER_PORT=9100

CONSUL_UI_PORT=8500
CONSUL_DNS_PORT=8600
JAEGER_UI_PORT=16686
JAEGER_ZIPKIN_PORT=9411
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318

RUN_CONSUL_REGISTER=1
SERVICE_DISCOVERY_DRIVER=consul
SERVICE_NAME=microservicio-produccion-cocina
SERVICE_ADDRESS=laravel_app
SERVICE_PORT=80
SERVICE_TAGS=laravel,produccion,cocina
SERVICE_HEALTH_PATH=/api/health
SERVICE_HEALTH_INTERVAL=15s
SERVICE_HEALTH_TIMEOUT=3s
SERVICE_DEREGISTER_AFTER=1m
CONSUL_HOST=consul
CONSUL_PORT=8500
CONSUL_SCHEME=http
CONSUL_TOKEN=

TRACING_ENABLED=true
TRACING_SERVICE_NAME=microservicio-produccion-cocina
TRACING_SAMPLE_RATE=1.0
TRACING_EXPORTER=zipkin
ZIPKIN_ENDPOINT=http://jaeger:9411/api/v2/spans

KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=classroom
KEYCLOAK_CLIENT_ID=api-gateway
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_BLOCKED_USERS=
KEYCLOAK_ISSUER=http://keycloak:8080/realms/classroom
KEYCLOAK_JWKS_TTL=600
KEYCLOAK_REQUIRE_DPOP=false
PACT_BYPASS_AUTH=false
PACT_BYPASS_HEADER_SECRET=

EVENTBUS_DRIVER=http
OUTBOX_SKIP_DISPATCH=false
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=outbox.events
RABBITMQ_EXCHANGE_TYPE=fanout
RABBITMQ_EXCHANGE_DURABLE=true
RABBITMQ_ROUTING_KEY=
RABBITMQ_QUEUE=
RABBITMQ_QUEUE_DURABLE=true
RABBITMQ_QUEUE_EXCLUSIVE=false
RABBITMQ_QUEUE_AUTO_DELETE=false
RABBITMQ_BINDING_KEY=
RABBITMQ_PUBLISH_RETRIES=3
RABBITMQ_PUBLISH_BACKOFF_MS=250
RABBITMQ_CONNECT_TIMEOUT=3
RABBITMQ_READ_WRITE_TIMEOUT=3
INBOUND_RABBITMQ_EXCHANGE=pacientes.events
INBOUND_RABBITMQ_EXCHANGE_TYPE=topic
INBOUND_RABBITMQ_EXCHANGE_DURABLE=true
INBOUND_RABBITMQ_QUEUE=paciente.paciente-creado
INBOUND_RABBITMQ_ROUTING_KEYS=paciente.paciente-creado,paciente.paciente-actualizado,paciente.paciente-eliminado
INBOUND_SCHEMA_VERSIONS=1
INBOUND_RABBITMQ_MAX_RETRIES=3
INBOUND_RABBITMQ_DLX=
INBOUND_RABBITMQ_DLQ=
INBOUND_RABBITMQ_DLQ_ROUTING_KEY=
INBOUND_RABBITMQ_RETRY_EXCHANGE=
INBOUND_RABBITMQ_RETRY_QUEUE=
INBOUND_RABBITMQ_RETRY_ROUTING_KEY=
INBOUND_RABBITMQ_RETRY_DELAYS=10,60,300
RUN_RABBITMQ_CONSUMER=1

DB_CONNECTION=mysql
DB_HOST=mysql_server
DB_PORT=3306
DB_DATABASE=produccion_cocina
DB_USERNAME=appuser
DB_PASSWORD=
DB_ROOT_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
OUTBOX_DISPATCH_SYNC=true
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
