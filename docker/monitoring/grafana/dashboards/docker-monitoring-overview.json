				},
				"textMode": "auto"
			},
			"targets": [
				{
					"expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
					"refId": "A"
				}
			],
			"title": "Server CPU Usage",
			"type": "stat"
		},
		{
			"datasource": {
				"type": "prometheus",
				"uid": "${prometheus_ds}"
			},
			"fieldConfig": {
				"defaults": {
					"color": {
						"mode": "thresholds"
					},
					"mappings": [],
