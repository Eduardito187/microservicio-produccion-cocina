				{
					"expr": "100 * (1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|rootfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|rootfs\"}))",
