				"textMode": "auto"
			},
			"targets": [
				{
					"expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
					"refId": "A"
				}
			],
			"title": "Server Memory Usage",
			"type": "stat"
		},
		{
			"datasource": {
				"type": "prometheus",
				"uid": "${prometheus_ds}"
			},
			"fieldConfig": {
				"defaults": {
					"color": {
						"mode": "thresholds"
					},
					"mappings": [],
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{
								"color": "green",
								"value": null
							},
							{
								"color": "red",
								"value": 80
							}
						]
					},
					"unit": "percent"
